<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en">
<head>
    <meta charset="utf-8"/>
    <title>Answer {{ card.id }}</title>
    <link rel="stylesheet" type="text/css" href="styles/kindle.css"/>
    <style>
        .code-block {
            font-family: "Courier New", Courier, monospace;
            background-color: #f4f4f4;
            border: 1px solid #ccc;
            padding: 10px;
            white-space: pre-wrap;
            font-size: 0.9em;
            margin-bottom: 15px;
        }
        .section-label {
            font-weight: bold;
            margin-bottom: 5px;
            text-transform: uppercase;
            border-bottom: 1px solid #ccc;
            padding-bottom: 3px;
        }
    </style>
</head>
<body>
    <p class="card-number">Explanation — Card {{ card.id }} of {{ total }}</p>

    <h2 style="text-align: center; margin-bottom: 15px;">{{ card.concept_name }}</h2>

    <div class="section-label">Explanation &amp; Tips</div>
    <div class="explanation-text code-block">
        {{ card.explanation }}
    </div>

    <div class="section-label" style="margin-top: 15px;">Example</div>
    <div class="code-block">
        {{ card.example_content }}
    </div>

    <p class="source-hint">Source: {{ card.source_hint }}</p>

    <div class="nav-row">
        {% if card.id < total %}
        <a class="btn btn-full" href="q{{ card.id + 1 }}.xhtml">Next Concept →</a>
        {% else %}
        <a class="btn btn-full" href="index.xhtml">Back to Contents</a>
        {% endif %}
    </div>
</body>
</html>
